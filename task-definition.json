{
  "containerDefinitions": [
    {
      "name": "fastapi-api",
      "image": "147885329467.dkr.ecr.eu-north-1.amazonaws.com/k8s-fastapi-ecr:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "name": "fastapi-api-8000-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/k8s-fastapi-cdk",
          "awslogs-create-group": "true",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        },
        "secretOptions": []
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8000/health/ready || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 10,
        "startPeriod": 3
      },
      "secrets": [
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:147885329467:secret:prod/k8s-fastapi/config:DATABASE_URL::"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:147885329467:secret:prod/k8s-fastapi/config:SECRET_KEY::"
        }
      ]
    }
  ],
  "family": "k8s-fastapi-task",
  "executionRoleArn": "arn:aws:iam::147885329467:role/K8sFastapiStack-K8sFastapiTaskDefExecutionRoleC911B-Mz7Dvqp9TpkQ",
  "taskRoleArn": "arn:aws:iam::147885329467:role/K8sFastapiStack-K8sFastapiTaskDefTaskRoleBD68D44D-qrKml56MfH3o",
  "networkMode": "awsvpc",
  "volumes": [],
  "placementConstraints": [],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "2048",
  "tags": []
}